{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "block w-full text-left bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-5 hover:border-slate-300 dark:hover:border-slate-600 hover:shadow-sm transition-all"
  },
  "responsive": {
    "portable": {
      "props": {
        "className": "block w-full text-left bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-4 hover:border-slate-300 dark:hover:border-slate-600 hover:shadow-sm transition-all"
      }
    }
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-start justify-between mb-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex items-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "file-text",
                "size": "lg",
                "className": "text-slate-600 dark:text-slate-400 flex-shrink-0"
              }
            },
            {
              "type": "basic",
              "name": "H3",
              "props": {
                "className": "font-semibold text-slate-900 dark:text-white"
              },
              "text": "{{board.name}}"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Span",
          "props": {
            "className": "px-2 py-0.5 text-sm font-medium text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 rounded"
          },
          "text": "$t:board.post_count|count={{board.posts_count ?? 0}}"
        }
      ]
    },
    {
      "type": "basic",
      "name": "P",
      "props": {
        "className": "text-sm text-slate-600 dark:text-slate-400 line-clamp-2 mb-3"
      },
      "text": "{{board.description ?? ''}}"
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "mb-4 flex flex-wrap gap-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "Span",
          "if": "{{board.slug === 'notice'}}",
          "props": {
            "className": "rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700 dark:bg-amber-900/30 dark:text-amber-300"
          },
          "text": "$t:board.directory.groups.announcements"
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{board.slug === 'free'}}",
          "props": {
            "className": "rounded-full bg-sky-50 px-2 py-0.5 text-xs font-medium text-sky-700 dark:bg-sky-900/30 dark:text-sky-300"
          },
          "text": "$t:board.directory.groups.discussion"
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{board.slug === 'qna'}}",
          "props": {
            "className": "rounded-full bg-teal-50 px-2 py-0.5 text-xs font-medium text-teal-700 dark:bg-teal-900/30 dark:text-teal-300"
          },
          "text": "$t:board.directory.groups.questions"
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{board.slug === 'resources'}}",
          "props": {
            "className": "rounded-full bg-violet-50 px-2 py-0.5 text-xs font-medium text-violet-700 dark:bg-violet-900/30 dark:text-violet-300"
          },
          "text": "$t:board.directory.groups.resources"
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{board.slug === 'introductions'}}",
          "props": {
            "className": "rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300"
          },
          "text": "$t:board.directory.groups.introductions"
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{board.slug === 'support'}}",
          "props": {
            "className": "rounded-full bg-rose-50 px-2 py-0.5 text-xs font-medium text-rose-700 dark:bg-rose-900/30 dark:text-rose-300"
          },
          "text": "$t:board.directory.groups.support"
        },
        {
          "type": "basic",
          "name": "Span",
          "if": "{{!['notice','free','qna','resources','introductions','support'].includes(board.slug)}}",
          "props": {
            "className": "rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600 dark:bg-slate-700 dark:text-slate-300"
          },
          "text": "$t:board.directory.groups.other"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex flex-wrap items-center justify-end gap-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "inline-flex items-center gap-1.5 rounded-md border border-slate-200 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-700"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/{{board.slug}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:board.view_board"
            },
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "arrow-right",
                "size": "sm"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "if": "{{board?.user_abilities?.can_write === true || board?.abilities?.can_write === true}}",
          "props": {
            "type": "button",
            "className": "inline-flex items-center gap-1.5 rounded-md bg-teal-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-teal-700 dark:bg-teal-500 dark:text-slate-950 dark:hover:bg-teal-400"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/{{board.slug}}/write"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "square-pen",
                "size": "sm"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:board.write"
            }
          ]
        }
      ]
    }
  ]
}
