{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "bg-transparent dark:bg-transparent rounded-none p-3 border-0 h-full flex flex-col opacity-90"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-center justify-between mb-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-sm font-medium text-slate-600 dark:text-slate-300 flex items-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "clock",
                "className": "w-3.5 h-3.5 text-slate-400 dark:text-slate-500"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:home.recent_posts"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "text-xs font-medium text-slate-500 dark:text-slate-500 hover:text-teal-600 dark:hover:text-teal-300 hover:underline flex items-center gap-1 cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/boards/popular"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.more"
            },
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "arrow-right",
                "className": "w-4 h-4"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') !== 'notice';}).length > 0}}",
      "props": {
        "className": "space-y-1 mb-1"
      },
      "iteration": {
        "source": "{{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') !== 'notice';})}}",
        "item_var": "post"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "block w-full text-left hover:bg-white/45 dark:hover:bg-slate-900/20 rounded-md px-2 py-1.5 transition-colors cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/{{post?.board_slug ?? ''}}/{{post?.id ?? ''}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center justify-between gap-2 text-xs"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center gap-2 flex-1 min-w-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(post?.board_slug ?? '') === 'notice'}}",
                      "props": {
                        "className": "text-slate-500 dark:text-slate-400 shrink-0"
                      },
                      "text": "$t:home.space_labels.notice"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(post?.board_slug ?? '') === 'free'}}",
                      "props": {
                        "className": "text-slate-500 dark:text-slate-400 shrink-0"
                      },
                      "text": "$t:home.space_labels.free"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(post?.board_slug ?? '') === 'qna'}}",
                      "props": {
                        "className": "text-slate-500 dark:text-slate-400 shrink-0"
                      },
                      "text": "$t:home.space_labels.qna"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(post?.board_slug ?? '') === 'resources'}}",
                      "props": {
                        "className": "text-slate-500 dark:text-slate-400 shrink-0"
                      },
                      "text": "$t:home.space_labels.resources"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(post?.board_slug ?? '') === 'introductions'}}",
                      "props": {
                        "className": "text-slate-500 dark:text-slate-400 shrink-0"
                      },
                      "text": "$t:home.space_labels.introductions"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(post?.board_slug ?? '') === 'support'}}",
                      "props": {
                        "className": "text-slate-500 dark:text-slate-400 shrink-0"
                      },
                      "text": "$t:home.space_labels.support"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{!['notice','free','qna','resources','introductions','support'].includes(post?.board_slug ?? '')}}",
                      "props": {
                        "className": "text-slate-500 dark:text-slate-400 shrink-0"
                      },
                      "text": "{{post?.board_name ?? ''}}"
                    },
                    {
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{post?.is_secret ?? false}}",
                      "props": {
                        "name": "lock",
                        "className": "w-3.5 h-3.5 text-slate-400 dark:text-slate-500 shrink-0"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-sm font-medium text-slate-700 dark:text-slate-200 text-left line-clamp-1"
                      },
                      "text": "{{post?.title ?? ''}}"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post?.is_new ?? false}}",
                      "props": {
                        "className": "px-1.5 py-0.5 text-xs bg-red-500 text-white rounded shrink-0"
                      },
                      "text": "$t:board.new_badge"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(post?.comment_count ?? 0) > 0}}",
                      "props": {
                        "className": "text-xs font-medium text-slate-500 dark:text-slate-400 shrink-0"
                      },
                      "text": "$t:home.comment_count_badge|count={{post?.comment_count ?? 0}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-xs text-slate-500 dark:text-slate-400 shrink-0",
                    "title": "{{post?.created_at ?? ''}}"
                  },
                  "text": "{{post?.created_at_formatted ?? ''}}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') !== 'notice';}).length === 0}}",
      "props": {
        "className": "text-center py-4 px-3 text-slate-500 dark:text-slate-500 flex-grow flex flex-col items-center justify-center min-h-[120px] rounded-md border border-dashed border-slate-200/25 dark:border-slate-800/45 bg-transparent"
      },
      "children": [
        {
          "type": "basic",
          "name": "Icon",
          "props": {
            "name": "message-square-plus",
            "className": "w-7 h-7 mx-auto mb-2 text-teal-500/70 dark:text-teal-400/70"
          }
        },
        {
          "type": "basic",
          "name": "H4",
          "props": {
            "className": "text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
          },
          "text": "$t:home.recent_posts_empty_title"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm max-w-sm"
          },
          "text": "$t:home.recent_posts_empty_description"
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "mt-3 inline-flex items-center gap-1 text-sm font-medium text-teal-600 dark:text-teal-400 hover:underline cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/boards"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:home.empty_browse_boards"
            },
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "arrow-right",
                "className": "w-4 h-4"
              }
            }
          ]
        }
      ]
    }
  ]
}
