{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "rounded-md border border-slate-200/40 bg-white/45 p-2.5 dark:border-slate-800/60 dark:bg-slate-900/25"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "mb-1 flex items-center justify-between gap-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "flex items-center gap-2 text-xs font-semibold text-slate-600 dark:text-slate-300"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "fire",
                "size": "sm",
                "className": "text-slate-400 dark:text-slate-500"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:home.recommended_spaces.title"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "rounded-md text-xs font-medium text-slate-400 ring-1 ring-transparent transition-colors hover:bg-teal-50/70 hover:text-teal-800 hover:ring-teal-200/70 dark:text-slate-500 dark:hover:bg-teal-900/30 dark:hover:text-teal-200 dark:hover:ring-teal-800/70 cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/boards"
              }
            }
          ],
          "text": "$t:home.board_discovery.view_all"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Ul",
      "if": "{{(popular_boards?.data ?? []).length > 0}}",
      "props": {
        "className": "grid grid-cols-1 gap-1.5"
      },
      "iteration": {
        "source": "{{(popular_boards?.data ?? []).slice(0, 6)}}",
        "item_var": "board",
        "index_var": "index"
      },
      "children": [
        {
          "type": "basic",
          "name": "Li",
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "grid w-full grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-2 rounded-md border border-slate-200/40 bg-white/55 px-2.5 py-1.5 text-left transition-colors hover:bg-white/75 dark:border-slate-800/60 dark:bg-slate-950/20 dark:hover:bg-slate-900/45 cursor-pointer"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "navigate",
                  "params": {
                    "path": "/board/{{board?.slug ?? ''}}"
                  }
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "flex h-5 w-5 items-center justify-center rounded-full bg-slate-100/70 text-[11px] font-semibold text-slate-500 dark:bg-slate-800/60 dark:text-slate-400"
                  },
                  "text": "{{index + 1}}"
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "min-w-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(board?.slug ?? '') === 'notice'}}",
                      "props": {
                        "className": "block truncate text-sm font-medium text-slate-800 dark:text-slate-100"
                      },
                      "text": "$t:home.space_labels.notice"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(board?.slug ?? '') === 'free'}}",
                      "props": {
                        "className": "block truncate text-sm font-medium text-slate-800 dark:text-slate-100"
                      },
                      "text": "$t:home.space_labels.free"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(board?.slug ?? '') === 'qna'}}",
                      "props": {
                        "className": "block truncate text-sm font-medium text-slate-800 dark:text-slate-100"
                      },
                      "text": "$t:home.space_labels.qna"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(board?.slug ?? '') === 'resources'}}",
                      "props": {
                        "className": "block truncate text-sm font-medium text-slate-800 dark:text-slate-100"
                      },
                      "text": "$t:home.space_labels.resources"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(board?.slug ?? '') === 'introductions'}}",
                      "props": {
                        "className": "block truncate text-sm font-medium text-slate-800 dark:text-slate-100"
                      },
                      "text": "$t:home.space_labels.introductions"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(board?.slug ?? '') === 'support'}}",
                      "props": {
                        "className": "block truncate text-sm font-medium text-slate-800 dark:text-slate-100"
                      },
                      "text": "$t:home.space_labels.support"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{!['notice','free','qna','resources','introductions','support'].includes(board?.slug ?? '')}}",
                      "props": {
                        "className": "block truncate text-sm font-medium text-slate-800 dark:text-slate-100"
                      },
                      "text": "{{board?.name ?? ''}}"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{(board?.description ?? '') !== ''}}",
                      "props": {
                        "className": "block truncate text-xs text-slate-500 dark:text-slate-400"
                      },
                      "text": "{{board?.description ?? ''}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "rounded bg-slate-100/70 px-1.5 py-0.5 text-xs font-medium text-slate-600 dark:bg-slate-800/70 dark:text-slate-300"
                  },
                  "text": "{{board?.posts_count ?? board?.post_count ?? board?.activity_count ?? 0 | number}}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{(popular_boards?.data ?? []).length === 0}}",
      "props": {
        "className": "rounded-md border border-dashed border-slate-200/60 px-3 py-2 dark:border-slate-800/70"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm font-medium text-slate-700 dark:text-slate-200"
          },
          "text": "$t:home.recommended_spaces.empty_title"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "mt-0.5 text-xs text-slate-500 dark:text-slate-400"
          },
          "text": "$t:home.recommended_spaces.empty_description"
        }
      ]
    }
  ]
}
