                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') === 'qna' && (post?.comment_count ?? 0) === 0;}).length > 0}}",
                  "props": {
                    "className": "mt-2 block truncate border-t border-amber-200/65 pt-1.5 text-xs font-medium text-amber-800 dark:border-amber-900/65 dark:text-amber-200"
