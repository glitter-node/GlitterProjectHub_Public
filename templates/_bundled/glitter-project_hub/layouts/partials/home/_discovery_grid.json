                  "props": {
                    "className": "mt-2 block truncate border-t border-sky-200/65 pt-1.5 text-xs font-medium text-sky-800 dark:border-slate-700 dark:text-slate-200"
                  },
                  "text": "{{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') === 'qna';})[0]?.title ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') === 'qna';}).length > 0}}",
                  "props": {
                    "className": "mt-0.5 block text-[11px] text-sky-700/80 dark:text-slate-400"
                  },
                  "text": "$t:home.discovery_grid.latest_meta|time={{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') === 'qna';})[0]?.created_at_formatted ?? ''}}|count={{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') === 'qna';})[0]?.comment_count ?? 0}}"
