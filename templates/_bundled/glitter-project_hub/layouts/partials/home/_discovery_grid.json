    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "grid grid-cols-1 gap-2"
      },
      "responsive": {
        "tablet": {
          "props": {
            "className": "grid grid-cols-2 gap-2"
          }
        },
        "desktop": {
          "props": {
            "className": "grid grid-cols-4 gap-2"
          }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "flex min-w-0 items-start gap-2 rounded-md border border-sky-200/70 bg-sky-50/70 px-3 py-2 text-left transition-colors hover:bg-sky-100/80 dark:border-slate-700 dark:bg-slate-800/60 dark:hover:bg-slate-800 cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "switch",
              "params": {
                "value": "{{_global.currentUser?.uuid ? 'authenticated' : 'guest'}}"
              },
              "cases": {
                "authenticated": {
                  "handler": "navigate",
                  "params": {
                    "path": "/board/qna/write"
                  }
                },
                "guest": {
                  "handler": "navigate",
                  "params": {
                    "path": "/login",
                    "query": {
                      "redirect": "/board/qna/write"
                    }
                  }
                }
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "question-circle",
                "size": "sm",
                "className": "mt-0.5 shrink-0 text-sky-600 dark:text-primary-300"
              }
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "min-w-0"
              },
              "children": [
