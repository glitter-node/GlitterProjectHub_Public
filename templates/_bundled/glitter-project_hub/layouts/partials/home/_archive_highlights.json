{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "rounded-md border border-teal-200/70 bg-white p-3 dark:border-teal-900/60 dark:bg-slate-800/70"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "mb-2 flex items-center justify-between gap-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "flex items-center gap-2 text-base font-semibold text-slate-900 dark:text-slate-50"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "folder-open",
                "size": "sm",
                "className": "text-teal-500 dark:text-teal-400"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:home.archive_highlights.title"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "variant": "outline",
            "size": "sm",
            "className": "gap-1.5 cursor-pointer border-teal-200/70 bg-teal-50/60 text-xs font-medium text-teal-800 transition-colors hover:border-teal-300 hover:bg-teal-100/80 hover:text-teal-900 dark:border-teal-900/65 dark:bg-teal-950/25 dark:text-teal-200 dark:hover:border-teal-700 dark:hover:bg-teal-900/40 dark:hover:text-teal-100"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/resources"
              }
            }
          ],
          "text": "$t:common.more"
        }
      ]
    },
    {
      "type": "basic",
      "name": "Ul",
      "if": "{{(resource_posts?.data?.data ?? []).length > 0}}",
      "props": {
        "className": "divide-y divide-slate-200/50 border-y border-slate-200/50 dark:divide-slate-700/65 dark:border-slate-700/65"
      },
      "iteration": {
        "source": "{{resource_posts?.data?.data ?? []}}",
        "item_var": "resource"
      },
      "children": [
        {
          "type": "basic",
          "name": "Li",
          "props": {
            "className": "py-1"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "grid w-full grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-2 rounded-md px-2 py-1 text-left transition-colors hover:bg-slate-50 dark:hover:bg-slate-800 cursor-pointer"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "navigate",
                  "params": {
                    "path": "/board/{{resource?.board_slug ?? resource?.slug ?? 'resources'}}/{{resource?.id ?? ''}}"
                  }
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "flex h-6 w-6 items-center justify-center rounded-full bg-teal-50 text-teal-700 dark:bg-slate-700 dark:text-primary-300"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "folder-open",
                        "size": "sm"
                      }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "min-w-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "block truncate text-sm font-medium text-slate-800 dark:text-slate-100"
                      },
                      "text": "{{resource?.title ?? ''}}"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "mt-0.5 inline-flex rounded bg-slate-100/70 px-1.5 py-0.5 text-[11px] font-medium text-slate-500 dark:bg-slate-800/55 dark:text-slate-400"
                      },
                      "text": "$t:home.archive_highlights.revisit_label"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "mt-0.5 block text-xs text-slate-500 dark:text-slate-400"
                      },
                      "text": "$t:home.archive_highlights.resource_meta|time={{resource?.created_at_formatted ?? resource?.created_at ?? ''}}|count={{resource?.comment_count ?? 0}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "chevron-right",
                    "size": "sm",
                    "className": "text-slate-400 dark:text-slate-500"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{(resource_posts?.data?.data ?? []).length === 0}}",
      "props": {
        "className": "rounded-md border border-dashed border-slate-200/60 px-3 py-2 dark:border-slate-800/70"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm font-medium text-slate-700 dark:text-slate-200"
          },
          "text": "$t:home.archive_highlights.empty_title"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "mt-0.5 text-xs text-slate-500 dark:text-slate-400"
          },
          "text": "$t:home.archive_highlights.empty_description"
        },
        {
          "type": "basic",
          "name": "Ul",
          "if": "{{(popular_boards?.data ?? []).length > 0}}",
          "props": {
            "className": "mt-2 grid grid-cols-1 gap-1"
          },
          "iteration": {
            "source": "{{(popular_boards?.data ?? []).slice(0, 3)}}",
            "item_var": "archive_space"
          },
          "children": [
            {
              "type": "basic",
              "name": "Li",
              "props": {
                "className": "flex items-center justify-between gap-2 rounded bg-slate-50 px-2 py-1 text-xs dark:bg-slate-950/35"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "truncate text-slate-600 dark:text-slate-300"
                  },
                  "text": "$t:home.archive_highlights.space_signal"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "shrink-0 text-slate-500 dark:text-slate-400"
                  },
                  "text": "$t:home.archive_highlights.space_meta|count={{archive_space?.posts_count ?? archive_space?.post_count ?? archive_space?.activity_count ?? 0}}"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
