{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "bg-transparent dark:bg-transparent rounded-none p-3 border-0 h-full opacity-95"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex flex-col gap-2 mb-2"
      },
      "responsive": {
        "tablet": {
          "props": {
            "className": "flex flex-row items-start justify-between gap-3 mb-2"
          }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "min-w-0"
          },
          "children": [
            {
              "type": "basic",
              "name": "H3",
              "props": {
                "className": "text-sm font-medium text-slate-700 dark:text-slate-300 flex items-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                "props": {
                  "name": "megaphone",
                  "size": "sm",
                  "className": "text-slate-400 dark:text-slate-500"
                }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:home.community_notice_panel.title"
                }
              ]
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "mt-1 text-xs text-slate-500 dark:text-slate-500"
              },
              "text": "$t:home.community_notice_panel.description"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "text-xs font-medium text-slate-500 dark:text-slate-500 hover:text-slate-800 dark:hover:text-slate-300 hover:underline flex items-center gap-1 cursor-pointer self-start"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/notice"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:home.community_notice_panel.view_notices"
            },
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "arrow-right",
                "size": "sm"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') === 'notice';}).length > 0}}",
      "props": {
        "className": "space-y-1.5"
      },
      "iteration": {
        "source": "{{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') === 'notice';}).slice(0, 2)}}",
        "item_var": "post"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "block w-full text-left rounded-md border border-slate-200/35 dark:border-slate-800/55 bg-white/30 dark:bg-slate-900/20 px-3 py-2 hover:border-slate-300/60 dark:hover:border-slate-700 transition-colors cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/notice/{{post?.id ?? ''}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-2 min-w-0"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-xs font-semibold text-slate-500 dark:text-slate-400 shrink-0"
                  },
                  "text": "$t:home.space_labels.notice"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm font-medium text-slate-700 dark:text-slate-200 line-clamp-1"
                  },
                  "text": "{{post?.title ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{post?.is_new ?? false}}",
                  "props": {
                    "className": "px-1.5 py-0.5 text-xs bg-red-500 text-white rounded shrink-0"
                  },
                  "text": "$t:board.new_badge"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "mt-1 block text-xs text-slate-500 dark:text-slate-400",
                "title": "{{post?.created_at ?? ''}}"
              },
              "text": "{{post?.created_at_formatted ?? ''}}"
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') === 'notice';}).length === 0}}",
      "props": {
        "className": "rounded-md border border-dashed border-slate-200/25 dark:border-slate-800/45 bg-transparent p-2.5"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm font-medium text-slate-600 dark:text-slate-300"
          },
          "text": "$t:home.community_notice_panel.empty_title"
        },
        {
          "type": "basic",
          "name": "Ul",
          "props": {
            "className": "mt-2 grid gap-1 text-xs text-slate-500 dark:text-slate-500"
          },
          "children": [
            {
              "type": "basic",
              "name": "Li",
              "props": {
                "className": "flex gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-slate-400"
                  },
                  "text": "$t:home.guide_bullet"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:home.community_notice_panel.guidance_1"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Li",
              "props": {
                "className": "flex gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-slate-400"
                  },
                  "text": "$t:home.guide_bullet"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:home.community_notice_panel.guidance_2"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Li",
              "props": {
                "className": "flex gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-slate-400"
                  },
                  "text": "$t:home.guide_bullet"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:home.community_notice_panel.guidance_3"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
